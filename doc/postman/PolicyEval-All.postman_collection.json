              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/periods?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "admin", "periods"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "isActive", "value": "", "disabled": true }
              ]
            }
          },
          "response": [
            {
              "name": "List Success",
              "code": 200,
              "body": "{\n  \"status\": true,\n  \"message\": \"Periods retrieved successfully\",\n  \"data\": {\n    \"contents\": [\n      {\n        \"id\": 1,\n        \"name\": \"Periode 2026 Ganjil\",\n        \"description\": \"Evaluasi semester ganjil\",\n        \"startDate\": \"2026-08-01T00:00:00.000000Z\",\n        \"endDate\": \"2026-12-31T00:00:00.000000Z\",\n        \"isActive\": true,\n        \"created_at\": \"2026-07-15T00:00:00.000000Z\",\n        \"updated_at\": \"2026-07-15T00:00:00.000000Z\"\n      }\n    ],\n    \"meta\": {\n      \"page\": 1,\n      \"limit\": 10,\n      \"total\": 1\n    }\n  }\n}"
            },
            {
              "name": "List Empty",
              "code": 200,
              "body": "{\n  \"status\": true,\n  \"message\": \"Periods retrieved successfully\",\n  \"data\": {\n    \"contents\": [],\n    \"meta\": {\n      \"page\": 1,\n      \"limit\": 10,\n      \"total\": 0\n    }\n  }\n}"
            }
          ]
        },
